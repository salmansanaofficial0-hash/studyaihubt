# Google AI API Key
# Get your key from: https://aistudio.google.com/app/apikeys
GOOGLE_AI_API_KEY=your_api_key_here
VITE_GOOGLE_AI_API_KEY=your_api_key_here

# Supabase (Study AI Hub project: bcvmjmofkvucrgpbypbf)
# Get keys from: https://supabase.com/dashboard/project/bcvmjmofkvucrgpbypbf/settings/api
VITE_SUPABASE_URL=https://bcvmjmofkvucrgpbypbf.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Optional alias (client accepts either name)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# Server-side (SSR / Netlify functions)
SUPABASE_URL=https://bcvmjmofkvucrgpbypbf.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Netlify: add VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in Site Settings > Environment Variables,
# then trigger a new deploy for changes to take effect.
